  _find (name) {⎩168⎭
      ⌈ "( name -- cfa|0) Find CFA of word name." ⌉⎩169⎭
      deftemp x ⇐ State.LAST⎩170⎭
      while (x >= 0) {⎩171⎭
	  ⌈ ## print(f"-- {x} : {RAM[x]}, {RAM[x + 1]}")  # Debug. ⌉⎩172⎭
	  if (name = State.RAM[x + 1]) {  ⌈ # Match! ⌉⎩173⎭
	      return x + 3⎩174⎭
	  } else {⎩175⎭
	      x ⇐ State.RAM[x]  ⌈ # Get next link. ⌉⎩176⎭
	  }⎩177⎭
      }⎩178⎭
      return 0  ⌈ # Nothing found. ⌉⎩179⎭
  }⎩180⎭
