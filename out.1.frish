  _find (name) {⎩174⎭
      ⌈ "( name -- cfa|0) Find CFA of word name." ⌉⎩175⎭
      deftemp x ⇐ State.LAST⎩176⎭
      while (x >= 0) {⎩177⎭
	  ⌈ ## print(f"-- {x} : {RAM[x]}, {RAM[x + 1]}")  # Debug. ⌉⎩178⎭
	  if (name = State.RAM[x + 1]) {  ⌈ # Match! ⌉⎩179⎭
	      return x + 3⎩180⎭
	  } else {⎩181⎭
	      x ⇐ State.RAM[x]  ⌈ # Get next link. ⌉⎩182⎭
	  }⎩183⎭
      }⎩184⎭
      return 0  ⌈ # Nothing found. ⌉⎩185⎭
  }⎩186⎭
