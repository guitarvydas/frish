  }⎩650⎭
⎩651⎭
  subr interpret {⎩652⎭
      ⌈ ( string --) Execute word. ⌉⎩653⎭
⎩654⎭
      @find⎩655⎭
      ⌈ 3 possible results from find:⎩656⎭
	  1. (name 0) if not found,⎩657⎭
	  2. (xt 1) if found and word is immediate,⎩658⎭
	  3. (xt -1) if found and word is normal ⌉⎩659⎭
      deftemp result ⇐ %pop					    defsynonym foundimmediate ≡ (result = 1)⎩660⎭
      deftemp item ⇐ %pop						    defsynonym foundnormal ≡ (result = -1)⎩661⎭
								      defsynonym notfound ≡ (result = 0)⎩662⎭
								      defsynonym found ≡ (foundimmediate or foundnormal)⎩663⎭
⎩664⎭
      if (found) {⎩665⎭
          if (%incompilingstate) {⎩666⎭
              if (foundimmediate) {⎩667⎭
                  λexec(item)⎩668⎭
              } else {⎩669⎭
                  λcompileword(item)⎩670⎭
              }⎩671⎭
        ⎩672⎭
          } else {⎩673⎭
              λexec(item)⎩674⎭
          }⎩675⎭
    ⎩676⎭
      } else {⎩677⎭
          if (%incompilingstate) {⎩678⎭
              if (%isinteger(item)) {⎩679⎭
                  λcompileinteger(item)⎩680⎭
              } else {⎩681⎭
                  if (%isfloat(item)) {⎩682⎭
                      λcompilefloat(item)⎩683⎭
                  } else {⎩684⎭
                      %returnFalse⎩685⎭
                  }⎩686⎭
            ⎩687⎭
              }⎩688⎭
        ⎩689⎭
          } else {⎩690⎭
              if (%isinteger(item)) {⎩691⎭
                  λpushasinteger(item)⎩692⎭
              } else {⎩693⎭
                  if (%isfloat(item)) {⎩694⎭
                      λpushasfloat(item)⎩695⎭
                  } else {⎩696⎭
                      %returnFalse⎩697⎭
                  }⎩698⎭
            ⎩699⎭
              }⎩700⎭
        ⎩701⎭
          }⎩702⎭
    ⎩703⎭
      }⎩704⎭
⎩705⎭
      %returnTrue⎩706⎭
        ⎩707⎭
    }⎩708⎭
    ⎩709⎭
⎩710⎭
invoke {⎩711⎭
  λok ()⎩712⎭
}⎩713⎭