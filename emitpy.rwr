SubroutineDefinition_immediate [_subr _imm ws token block n] =
‛case "«token»":⤷\nState.compiling.push (False)\nState.compiling = False«block»\nState.compiling = State.compiling.pop ()⤶«n»\n’
SubroutineDefinition_normal [_subr ws token block n] = ‛\ncase "«token»":⤷«block»⤶«n»\n’

