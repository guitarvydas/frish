% rewrite emitPython {

Main [sf i] = ‛
import re

class Stack(list):⤷
    def push(my, *items):⤷
        my.extend(items)⤶⤶

class StateClass:⤷
    def __init__ (self):⤷
        self.S = Stack() 
        self.R = Stack()
        self.RAM = []
        self.LAST = -1
        self.IP = None
        self.W = None;
        self.BUFF = ""
        self.BUFP = 0
	self.compiling = [False]⤶⤶

State = StateClass ()

«sf»
«i»’

