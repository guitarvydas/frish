deffunction _find (name) {⎩176⎭
    ⌈ "( name -- cfa|0) Find CFA of word name." ⌉⎩177⎭
    deftemp x ⇐ State.LAST⎩178⎭
    while (x >= 0) {⎩179⎭
        ⌈ ## print(f"-- {x} : {RAM[x]}, {RAM[x + 1]}")  # Debug. ⌉⎩180⎭
        if (name = State.RAM[x + 1]) {  ⌈ # Match! ⌉⎩181⎭
            return x + 3⎩182⎭
        } else {⎩183⎭
            x ⇐ State.RAM[x]  ⌈ # Get next link. ⌉⎩184⎭
	}⎩185⎭
    }⎩186⎭
    return 0  ⌈ # Nothing found. ⌉⎩187⎭
}⎩188⎭
