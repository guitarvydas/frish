  function code (name, flags, does) {⎩114⎭
      ⌈ Add new word to RAM dictionary. We create a word (Forth "object") in RAM with 5 fields and extend the⎩115⎭
	the dictionary by linking back to the head of the dictionary list ⌉⎩116⎭
      x ⇐ %funcall len (State.RAM)⎩117⎭
⎩118⎭
      %ram+ (State.LAST) ⌈ (LFA) link to previous word in dictionary list ⌉⎩119⎭
      %ram+ (name)       ⌈ (NFA) name of word ⌉⎩120⎭
      %ram+ (flags)      ⌈       0 = normal word, 1 = immediate word ⌉⎩121⎭
      %ram+ (does)       ⌈ (CFA) function pointer that points to code that executes the word ⌉⎩122⎭
⎩123⎭
      State.LAST ⇐ x                ⌈ LAST is the pointer to the head of the dictionary list, set it to point to⎩124⎭
					this new word ⌉⎩125⎭
  }⎩126⎭
⎩127⎭
  function literalize () {⎩128⎭
      ⌈ Compile literal into definition. ⌉⎩129⎭
      %ram+ (%funcall _find ("(literal)"))  ⌈# Compile address of doliteral. ⌉⎩130⎭
      %ram+ (%pop)             ⌈ # Compile literal value. ⌉⎩131⎭
  }⎩132⎭
