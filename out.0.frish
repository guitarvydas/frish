⎩388⎭
defsubr xdoliteral "(literal)" {⎩389⎭
    ⌈⎩390⎭
 Inside definitions only, pushes compiled literal to stack ⎩391⎭
    ⎩392⎭
     Certain Forth words are only applicable inside compiled sequences of subroutines ⎩393⎭
     Literals are handled in different ways when interpreted when in the REPL vs⎩394⎭
     compiled into sequences of subrs ⎩395⎭
     In the REPL, when we encounter a literal, we simply push it onto the stack ⎩396⎭
     In the compiler, though, we have to create an instruction that pushes ⎩397⎭
       the literal onto the stack. ⎩398⎭
       Compiled code doesn't do what the REPL does, we have to hard-wire and ⎩399⎭
       bake in code that pushes the literal when the time comes to run the sequence. ⎩400⎭
⎩401⎭
     This word - "(literal)" - is a simple case and one could actually type this ⎩402⎭
       instruction into the REPL, but, that would be redundant.  Other kinds of words, ⎩403⎭
       e.g. some control-flow words, tend to be messier and the code below only handles ⎩404⎭
       the compiled aspects and ignores the REPL aspects ⎩405⎭
⎩406⎭
     "IP" is the current word index in a sequence of words being compiled. ⎩407⎭
⌉⎩408⎭
    defsynonym lit ≡ State.RAM [State.IP]⎩409⎭
    %push (lit)⎩410⎭
    State.IP ⇐ State.IP + 1 ⌈ move past this item (the literal) - we're done with it ⌉⎩411⎭
}⎩412⎭
⎩413⎭
defsubr xbranch "branch" {⎩414⎭
    ⌈ This instruction appears only inside subroutine sequences, jump to address in next cell ⌉⎩415⎭
    ⌈ This instruction is inserted into a subr sequence when compiling control-flow words, like "else" see below) ⌉⎩416⎭
    State.IP ⇐ State.RAM [State.IP]⎩417⎭
    ⌈ normally, we just execute an instruction then move the IP sequentially forward by 1 unit, i.e. IP ⇐ IP + 1 ⌉⎩418⎭
    ⌈   in this case, though, we explicitly change the IP to some other value and don't just increment it ⌉⎩419⎭
}⎩420⎭
⎩421⎭
defsubr x0branch "0branch" {⎩422⎭
    ⌈ This instruction appears only inside subroutine sequences, jump on false to address in next cell ⌉⎩423⎭
    deftemp test ⇐ %toboolean (%pop)⎩424⎭
    if (test) {⎩425⎭
        State.IP ⇐ State.IP + 1⎩426⎭
    } else {⎩427⎭
       State.IP ⇐ State.RAM [State.IP]⎩428⎭
    }⎩429⎭
}⎩430⎭
⎩431⎭
⎩432⎭
⌈ "immediate" words are fully operational even when in compile mode. Some (not all) of these words are meant to⎩433⎭
    work /only/ in compile mode. At the REPL prompt ("interpret" mode), they produce unwanted results.⎩434⎭
  immediate words: xif, xelse, xthen, xquote, xcomment, xsemi⎩435⎭
  immediate words that only have meaning in compile mode: xif, xelse, xthen, xsemi⎩436⎭
⌉⎩437⎭
⎩438⎭
⎩439⎭
⌈ IF, ELSE and THEN are "immediate" words - they should only be used inside of ":" (colon compiler) ⌉⎩440⎭
⎩441⎭
⌈ see diagram compiling-IF-THEN.drawio.png ⌉⎩442⎭
defsubr xif "if" { ⎩443⎭
    %immediate ⌈ This instruction appears only inside subroutine sequences, ( f -- ) compile if test and branchFalse ⌉ ⎩444⎭
    ⌈ Step. 1: generate conditional branch to yet-unknown target1 ⌉ ⎩445⎭
    deftemp branchFalseAddress ⇐ %funcall _find ("0branch")⎩446⎭
    %ram+ (branchFalseAddress) ⌈ insert branch-if-false opcode (word) ⌉ ⎩447⎭
    %rpush (%RAMnext) ⌈ target1 onto r-stack as memo for later fixup ⌉ ⎩448⎭
    defsynonym target1 ≡ -1 ⎩449⎭
    %ram+ (target1) ⌈ branch target will be fixed up later ⌉ ⎩450⎭
    ⌈ Step. 2: generate code for true branch - return to compiler which will compile the following words ⌉ ⎩451⎭
    ⌈ THEN or ELSE will do the fixup of target1 ⌉ ⎩452⎭
} ⎩453⎭
⎩454⎭
⌈ see diagram compiling-IF-ELSE-THEN.drawio.png ⌉⎩455⎭
defimmediatesubr xelse "else" {⎩456⎭
    ⌈ Step. 1: fixup target1 from IF-true, retrieving memo from R-stack ⌉⎩457⎭
    deftemp target1 ⇐ %rpop⎩458⎭
    State.RAM [target1] ⇐ %RAMnext⎩459⎭
    ⌈ Step. 2: generate unconditional branch for preceding IF, creating new memo for target2 on R-stack ⌉⎩460⎭
    deftemp brAddress ⇐ %funcall _find ("branch")⎩461⎭
    %rpush (%RAMnext) ⌈ target2 address on R-stack as memo for later fixup ⌉⎩462⎭
    defsynonym target2 ≡ -1⎩463⎭
    %ram+ (target2) ⌈ branch target will be fixed up later ⌉⎩464⎭
    ⌈ Step. 3: generate code for false branch - return to compiler which will compile the following words ⌉⎩465⎭
    ⌈ THEN will do the fixup of target2 ⌉⎩466⎭
}⎩467⎭
⎩468⎭
⌈ see diagrams compiling-IF-THEN.drawio.png and compiling-IF-ELSE-THEN.drawio.png ⌉⎩469⎭
defimmediatesubr xthen "then" {⎩470⎭
    ⌈ Step. 1: fixup target (from IF or from ELSE, above), retrieving memo from R-stack ⌉⎩471⎭
    deftemp target ⇐ %rpop⎩472⎭
    State.RAM [target] ⇐ %RAMnext⎩473⎭
}⎩474⎭
⎩475⎭
defsubr x_do "(do)" {⎩476⎭
    ⌈ ( limit index --) Puts limit and index on return stack. ⌉⎩477⎭
    @xswap⎩478⎭
    deftemp index ⇐ %pop⎩479⎭
    deftemp limit ⇐ %pop⎩480⎭
    %rpush (index)⎩481⎭
    %rpush (limit)⎩482⎭
}⎩483⎭
⎩484⎭
defimmediatesubr xdo "xdo" {⎩485⎭
    ⌈ (  limit index --) Begin counted loop. ⌉⎩486⎭
    %ram+(%funcall _find("(do)"))  ⌈ Push do loop handler. ⌉⎩487⎭
    %rpush(%RAMnext)           ⌈ Push address to jump back to. ⌉⎩488⎭
}⎩489⎭
⎩490⎭
defsubr x_loop "(loop)" {⎩491⎭
    ⌈ (  -- f) Determine if loop is done. ⌉⎩492⎭
    deftemp index ⇐ %rpop⎩493⎭
    deftemp limit ⇐ %rpop⎩494⎭
    defsynonym cond ≡ (index >= limit)⎩495⎭
    %push (cond)⎩496⎭
    if (cond) { ⌈ clean up rstack if index >= limit ⌉⎩497⎭
        %rpop⎩498⎭
        %rpop⎩499⎭
    }    ⎩500⎭
}⎩501⎭
⎩502⎭
defimmediatesubr xploop "+loop" {⎩503⎭
    ⌈ ( --) Close counted loop. ⌉⎩504⎭
    %ram+(%funcall _find("(loop)"))   ⌈ Compile in loop test. ⌉⎩505⎭
    %ram+(%funcall _find("0branch"))  ⌈ Compile in branch check. ⌉⎩506⎭
    %ram+(%rpop)           ⌈ Address to jump back to. ⌉⎩507⎭
}⎩508⎭
⎩509⎭
defimmediatesubr xloop "xloop" {⎩510⎭
    ⌈ (  --) Close counted loop. ⌉⎩511⎭
    %push (1)⎩512⎭
    @literalize                  ⌈ Default loop increment for x_loop. ⌉⎩513⎭
    %ram+(%funcall _find("(loop)"))   ⌈ Compile in loop test. ⌉⎩514⎭
    %ram+(%funcall _find("0branch"))  ⌈ Compile in branch check. ⌉⎩515⎭
    %ram+(%rpop)           ⌈ Address to jump back to. ⌉⎩516⎭
}⎩517⎭
⎩518⎭
defimmediatesubr xbegin "begin" {⎩519⎭
    %rpush (%RAMnext)  ⌈ ( --) Start indefinite loop. ⌉⎩520⎭
}⎩521⎭
⎩522⎭
defimmediatesubr xuntil "until" {⎩523⎭
    ⌈ (  f --) Close indefinite loop with test. ⌉⎩524⎭
    %ram+(%funcall _find("0branch"))  ⌈ Expects result of test on stack. ⌉⎩525⎭
    %ram+(%rpop)           ⌈ Address to jump back to. ⌉⎩526⎭
}⎩527⎭
⎩528⎭
⎩529⎭
⎩530⎭
⌈  "... 123 constant K ..." ⌉⎩531⎭
⌈  at interpretation time: 123 is on the Stack, we have consumed "constant" from BUFF, BUFF now contains "K ..." ⌉⎩532⎭
⌈  invoke 'word' which parses "K" and pushed it. The stack becomes [... 123 "K"] ⌉⎩533⎭
⌈  pop "K", pop 123, create a new word called 'K' with its PFA set to 123 and its CFA set to a subr that⎩534⎭
     gets 123 from its PFA and pushes it onto the stack ⌉⎩535⎭
defsubr xconst "const" {⎩536⎭
    ⌈  get next word - the name - from BUFF ⌉⎩537⎭
    defsynonym blank ≡ 32⎩538⎭
    %push (blank)⎩539⎭
    @xword⎩540⎭
    ⌈  stack is now: ( NNNN name -- ) ⌉⎩541⎭
    deftemp name ⇐ %pop⎩542⎭
    deftemp value ⇐ %pop⎩543⎭
    defsynonym normal ≡ 0⎩544⎭
    deftemp fobj ⇐ %funcall code (name, normal, ↪︎doconst)⎩545⎭
    %ram+ (value)⎩546⎭
}⎩547⎭
⎩548⎭
defsubr xcomma "," {⎩549⎭
    %funcall comma (%pop)⎩550⎭
}⎩551⎭
⎩552⎭
defsubr xvar "variable" {⎩553⎭
    defsynonym blank ≡ 32⎩554⎭
    %push (blank)⎩555⎭
    @xword⎩556⎭
    deftemp name ⇐ %pop⎩557⎭
    deftemp value ⇐ %pop⎩558⎭
    %funcall fvar (name, value)    ⎩559⎭
}⎩560⎭
⎩561⎭
defsubr xdump "dump" {⎩562⎭
    deftemp n ⇐ %toint (%pop)⎩563⎭
    deftemp start ⇐ %toint (%pop)⎩564⎭
    %print ("----------------------------------------------------------------")⎩565⎭
    deftemp a ⇐ start⎩566⎭
    while (a < start + (%funcall min (n, (%funcall len (State.RAM) - start)))) {⎩567⎭
        %print (a)⎩568⎭
	%print (": ")⎩569⎭
	%print (State.RAM [a])⎩570⎭
	%eol⎩571⎭
        deftemp a ⇐ a + 1⎩572⎭
    }⎩573⎭
}⎩574⎭
⎩575⎭
defsubr xstore"!" {⎩576⎭
    deftemp b ⇐ %pop⎩577⎭
    deftemp a ⇐ %pop⎩578⎭
    State.RAM [b] ⇐ a⎩579⎭
}⎩580⎭
⎩581⎭
defsubr xbye "bye" { ⌈ ( --) Leave interpreter ⌉ %quit }⎩582⎭
⎩583⎭
⎩584⎭
defsubr xfind "find" {⎩585⎭
    ⌈ "( name | -- (name 0)|(xt 1)|(xt -1)) Search for word name." ⌉⎩586⎭
    ⌈ 3 possible results: 1. (name 0) if not found, 2. (xt 1) if found and word is immediate, 3. (xt -1) if found and word is normal ⌉⎩587⎭
    %push (32)⎩588⎭
    @xword⎩589⎭
    deftemp found ⇐ %funcall _find(%stop)⎩590⎭
    if (0 = found) {⎩591⎭
        %push (0)⎩592⎭
    } else {⎩593⎭
        %pop  ⌈ # Get rid of name on stack. ⌉⎩594⎭
        %push(found)⎩595⎭
        deftemp immediate ⇐ -1⎩596⎭
        if (State.RAM[%stop - 1] & 1) { immediate ⇐ 1 }⎩597⎭
        %push(immediate)⎩598⎭
    }⎩599⎭
}⎩600⎭
⎩601⎭
defsubr xtick "'"  {⎩602⎭
    ⌈ "( name -- xt|-1) Search for execution token of word name." ⌉⎩603⎭
    %push (32)⎩604⎭
    @xword⎩605⎭
    deftemp name ⇐ %pop⎩606⎭
    deftemp found ⇐ %funcall _find(name)⎩607⎭
    %push (found)⎩608⎭
}⎩609⎭
⎩610⎭
defsubr xnone "None" {⎩611⎭
    %pushNone⎩612⎭
}⎩613⎭
⎩614⎭
defsubr xwords "words" {⎩615⎭
    ⌈ print words in dictionary ⌉⎩616⎭
    deftemp x ⇐ State.LAST⎩617⎭
    while (x > -1) {⎩618⎭
        %print (State.RAM [x+ 1])⎩619⎭
	%print (" ")⎩620⎭
    }⎩621⎭
    %eol⎩622⎭
}⎩623⎭
⎩624⎭
⎩625⎭
defsubr xexecute "execute" {⎩626⎭
    ⌈ invoke given word ⌉⎩627⎭
    deftemp wordAddress ⇐ %pop⎩628⎭
    @@wordAddress⎩629⎭
}⎩630⎭
⎩631⎭
⎩632⎭
defsubr xcolon ":" {⎩633⎭
    ⌈ ( name | --) Start compilation. ⌉⎩634⎭
    defsynonym blank ≡ 32⎩635⎭
    %push (blank)⎩636⎭
    @xword⎩637⎭
    deftemp name ⇐ %pop⎩638⎭
    %funcall code(name, 0, doword)⎩639⎭
    %setCompilingState⎩640⎭
}⎩641⎭
⎩642⎭
defimmediatesubr xsemi ";"{⎩643⎭
    ⌈ ( --) Finish definition. ⌉⎩644⎭
⎩645⎭
    %ram+(-1)  ⌈ Marker for end of definition. ⌉⎩646⎭
    %setNotCompilingState⎩647⎭
}⎩648⎭
⎩649⎭
defsubr xinterpret "interpret" {⎩650⎭
    ⌈ ( string --) Execute word. ⌉⎩651⎭
⎩652⎭
    @xfind⎩653⎭
    ⌈ 3 possible results from xfind:⎩654⎭
        1. (name 0) if not found,⎩655⎭
	2. (xt 1) if found and word is immediate,⎩656⎭
	3. (xt -1) if found and word is normal ⌉⎩657⎭
    deftemp result ⇐ %pop					    defsynonym foundimmediate ≡ (result = 1)⎩658⎭
    deftemp item ⇐ %pop						    defsynonym foundnormal ≡ (result = -1)⎩659⎭
    	    	   						    defsynonym notfound ≡ (result = 0)⎩660⎭
    	    	   						    defsynonym found ≡ (foundimmediate or foundnormal)⎩661⎭
⎩662⎭
    if (found) {⎩663⎭
        if (%incompilingstate) {⎩664⎭
            if (foundimmediate) {⎩665⎭
                λexec(item)⎩666⎭
            } else {⎩667⎭
                λcompileword(item)⎩668⎭
            }⎩669⎭
        ⎩670⎭
        } else {⎩671⎭
            λexec(item)⎩672⎭
        }⎩673⎭
    ⎩674⎭
    } else {⎩675⎭
        if (%incompilingstate) {⎩676⎭
            if (%isinteger(item)) {⎩677⎭
                λcompileinteger(item)⎩678⎭
            } else {⎩679⎭
                if (%isfloat(item)) {⎩680⎭
                    λcompilefloat(item)⎩681⎭
                } else {⎩682⎭
                    @returnFalse⎩683⎭
                }⎩684⎭
            ⎩685⎭
            }⎩686⎭
        ⎩687⎭
        } else {⎩688⎭
            if (%isinteger(item)) {⎩689⎭
                λpushasinteger(item)⎩690⎭
            } else {⎩691⎭
                if (%isfloat(item)) {⎩692⎭
                    λpushasfloat(item)⎩693⎭
                } else {⎩694⎭
                    @returnFalse⎩695⎭
                }⎩696⎭
            ⎩697⎭
            }⎩698⎭
        ⎩699⎭
        }⎩700⎭
    ⎩701⎭
    }⎩702⎭
⎩703⎭
    return True⎩704⎭
}⎩705⎭
⎩706⎭
⎩707⎭
⎩708⎭
@ok⎩709⎭
    ⎩710⎭