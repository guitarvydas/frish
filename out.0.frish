⎩172⎭
  function _find (name) {⎩173⎭
      ⌈ "( name -- cfa|0) Find CFA of word name." ⌉⎩174⎭
      deftemp x ⇐ State.LAST⎩175⎭
      while (x >= 0) {⎩176⎭
	  ⌈ ## print(f"-- {x} : {RAM[x]}, {RAM[x + 1]}")  # Debug. ⌉⎩177⎭
	  if (name = State.RAM[x + 1]) {  ⌈ # Match! ⌉⎩178⎭
	      return x + 3⎩179⎭
	  } else {⎩180⎭
	      x ⇐ State.RAM[x]  ⌈ # Get next link. ⌉⎩181⎭
	  }⎩182⎭
      }⎩183⎭
      return 0  ⌈ # Nothing found. ⌉⎩184⎭
  }⎩185⎭
